# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=replace_with_db_username
DB_PASSWORD=replace_with_db_password
DB_NAME=replace_with_database_name

# Seed Admin Configuration
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=replace_with_admin_email
SEED_ADMIN_DEPARTMENT=Orthodontics

# Optional: if omitted, system generates a temporary password
SEED_ADMIN_PASSWORD=your_admin_password

# JWT Configuration
JWT_SECRET=replace_with_jwt_secret_key
JWT_REFRESH_SECRET=replace_with_jwt_refresh_secret_key
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d
SESSION_TIMEOUT_SECONDS=3600

# Google Sign-In Configuration
GOOGLE_CLIENT_ID=replace_with_google_client_id.apps.googleusercontent.com

# Audit Log Retention
AUDIT_LOG_RETENTION_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=180
AUDIT_LOG_CLEANUP_INTERVAL_HOURS=24
AUDIT_LOG_CLEANUP_BATCH_SIZE=5000
AUDIT_LOG_ARCHIVE_BEFORE_DELETE=false

# File Upload Configuration
UPLOAD_DIR=./src/uploads
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Email Configuration
EMAIL_SIMULATION=true
SMTP_HOST=replace_with_smtp_host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_email_address
SMTP_PASS=replace_with_email_password_or_app_password
SMTP_FROM=replace_with_sender_email

# Logging
LOG_LEVEL=info
